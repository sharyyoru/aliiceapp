# ============================================
# ALiice - Multi-Tenant Medical CRM & ERP
# Environment Variables
# ============================================

# App Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ALiice

# Supabase project settings (replace with your new Supabase project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key for secure server-side operations only
# NEVER expose this in the browser!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider (e.g. OpenAI)
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# Email service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS=noreply@aliice.app
EMAIL_FROM_NAME=ALiice
EMAIL_REPLY_DOMAIN=aliice.app

# Stripe (for subscription billing)
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# WhatsApp Integration (optional)
WHATSAPP_API_URL=http://localhost:3001
WHATSAPP_API_KEY=your-whatsapp-api-key
